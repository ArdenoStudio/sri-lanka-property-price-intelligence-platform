DATABASE_URL=postgresql://nilam:password@localhost:5432/nilam_db
POSTGRES_USER=nilam
POSTGRES_PASSWORD=your_secure_password
POSTGRES_DB=nilam_db
NOMINATIM_USER_AGENT=nilam-geocoder/1.0 (your@email.com)
SCRAPE_INTERVAL_HOURS=24
LOG_LEVEL=INFO
ADMIN_API_KEY=change_me_admin_key
SCRAPER_MAX_RETRIES=3
SCRAPER_BACKOFF_BASE_SECONDS=5
SCRAPER_BACKOFF_MAX_SECONDS=60
SCRAPER_STOP_AFTER_BLOCKS=3

# API cutover flags (0=Playwright/HTML default, 1=enable)
USE_LPW_API=0
USE_IKMAN_SERP_API=0
USE_IKMAN_DETAIL_API=0
USE_DISTRICT_PROFILES=0

# LPW API tuning
LPW_API_PAGE_LIMIT=30
LPW_API_DELAY_SECONDS=0.35
LPW_API_MAX_PAGES=0
LPW_SECURE_KEY=2JIOMXS

# ikman API tuning
IKMAN_API_DELAY_SECONDS=0.4
IKMAN_API_MAX_PAGES=0
IKMAN_API_STOP_AFTER_DUP_PAGES=3
# 1 = location-sharded SERP (required to pass ~page-500 API wall for full catalog)
IKMAN_API_LOCATION_SHARD=0
IKMAN_API_PAGE_SOFT_LIMIT=350
IKMAN_API_IMAGE_URL_CAP=10
# IKMAN_API_CATEGORIES=415,942,937,416,938,939,940,413,943
ENRICHER_MAX_PER_RUN=500
