[Unit]
Description=Daily Property Scraper Timer
Requires=property-scraper.service

[Timer]
# Run daily at 2 AM
OnCalendar=daily
OnCalendar=*-*-* 02:00:00

# Run on boot if missed
Persistent=true

# Random delay up to 30 minutes to avoid exactly 2 AM
RandomizedDelaySec=30m

[Install]
WantedBy=timers.target
