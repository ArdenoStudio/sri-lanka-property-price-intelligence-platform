{
  "version": 2,
  "buildCommand": "cd dashboard && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "dashboard/dist",
  "framework": null,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "experimentalServices": {
    "web": {
      "routePrefix": "/"
    }
  }
}
