{
  "version": 2,
  "buildCommand": "cd dashboard && npm install --legacy-peer-deps && npm run build",
  "outputDirectory": "dashboard/dist",
  "framework": null,
  "env": {
    "VITE_API_URL": "https://6jzzb7iku2fxd5jxeunojg2bpm0pjeft.lambda-url.us-east-1.on.aws"
  },
  "rewrites": [
    { "source": "/((?!assets/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
